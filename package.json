{
  "name": "smlpos",
  "version": "1.9.906",
  "description": "SMLPOS — Système de Point de Vente Intelligent",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:browser": "vite --config vite.browser.config.ts",
    "build": "electron-vite build",
    "prepackage": "node scripts/check-env.mjs && node scripts/generate-icon.mjs",
    "preview": "electron-vite preview",
    "package": "npm run prepackage && npm run build && electron-builder",
    "package:msi": "npm run prepackage && npm run build && electron-builder --win msi",
    "package:nsis": "npm run prepackage && npm run build && electron-builder --win nsis",
    "release:win": "npm run prepackage && npm run build && electron-builder --win nsis --publish always",
    "release:win:local": "npm run build && electron-builder --win nsis --dir --config.win.signAndEditExecutable=false",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "pos",
    "electron",
    "react"
  ],
  "author": "SMLPOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sml-blip/smlpos.git"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.3",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.3",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.3",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.1.5",
    "@supabase/supabase-js": "^2.105.1",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.3.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-to-print": "^3.0.3",
    "recharts": "^2.14.1",
    "tailwind-merge": "^2.5.5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.smlpos.desktop",
    "productName": "SMLPOS",
    "copyright": "Copyright © 2026 SMLPOS",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "resources/**/*",
      "!node_modules/**/*.{ts,map}",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "icon": "resources/icon.png",
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SMLPOS-v${version}-Setup.${ext}",
      "signingHashAlgorithms": null,
      "sign": null,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "SMLPOS-v${version}-Portable.exe"
    },
    "msi": {
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SMLPOS",
      "upgradeCode": "A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SMLPOS",
      "allowElevation": true,
      "installerIcon": "resources/icon.ico",
      "artifactName": "SMLPOS-v${version}-Setup.${ext}"
    },
    "directories": {
      "buildResources": "resources",
      "output": "dist-v1.9.2"
    },
    "publish": {
      "provider": "github",
      "owner": "Sml-blip",
      "repo": "smlpos",
      "releaseType": "release"
    }
  }
}
